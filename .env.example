# ============================================================
# Behanian Project — Variables d'environnement
# ============================================================
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais commiter le fichier .env dans git.
# ============================================================

# ----- Sécurité -----
DJANGO_SECRET_KEY=remplacer-par-une-vraie-cle-secrete-longue-et-aleatoire
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=mondomaine.com,www.mondomaine.com

# ----- Base de données (production : PostgreSQL recommandé) -----
# Laisser vide pour utiliser SQLite (développement uniquement)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=behanian_db
DB_USER=behanian_user
DB_PASSWORD=mot_de_passe_base_de_donnees
DB_HOST=localhost
DB_PORT=5432

# ----- Email (production) -----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.monhébergeur.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@mondomaine.com
EMAIL_HOST_PASSWORD=mot_de_passe_email
